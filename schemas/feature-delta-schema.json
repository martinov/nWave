{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nwave.ai/schemas/feature-delta-schema.json",
  "$comment": "MIT License — Copyright (c) 2026 nWave contributors",
  "title": "feature-delta",
  "version": "1.1.0",
  "description": "Schema v1.1 for unified feature-delta.md — single source of truth per DD-D12 (US-INFRA-1). v1.1 (R1, US-11): Origin column annotation 'WAVE#rowN' supports row-level bijection check (E3b-row). Backward-compatible with v1.0 (Origin column optional).",
  "type": "object",
  "definitions": {
    "WaveSection": {
      "type": "object",
      "description": "A named wave section (DISCUSS, DESIGN, DISTILL, …) inside feature-delta.md.",
      "required": ["name", "heading", "rows"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Wave name — DISCUSS | DESIGN | DISTILL | DELIVER | DEVOPS | DISCOVER.",
          "enum": ["DISCUSS", "DESIGN", "DISTILL", "DELIVER", "DEVOPS", "DISCOVER"]
        },
        "heading": {
          "type": "string",
          "description": "Full heading text matching '## Wave: <NAME> / [REF|WHY|HOW] <Section>'.",
          "pattern": "^## Wave: (DISCUSS|DESIGN|DISTILL|DELIVER|DEVOPS|DISCOVER)"
        },
        "rows": {
          "type": "array",
          "items": { "$ref": "#/definitions/CommitmentRow" }
        },
        "design_decisions": {
          "type": "array",
          "items": { "$ref": "#/definitions/DesignDecision" }
        }
      }
    },
    "CommitmentRow": {
      "type": "object",
      "description": "A single row in a wave commitments table (Origin | Commitment | DDD | Impact).",
      "required": ["commitment", "impact"],
      "additionalProperties": false,
      "properties": {
        "origin": {
          "$ref": "#/definitions/OriginAnnotation"
        },
        "commitment": {
          "type": "string",
          "minLength": 1,
          "description": "Non-empty commitment text (E3)."
        },
        "ddd": {
          "type": "string",
          "description": "DDD reference or 'n/a'."
        },
        "impact": {
          "type": "string",
          "minLength": 1,
          "description": "Non-empty impact text (E3)."
        }
      }
    },
    "OriginAnnotation": {
      "type": "string",
      "description": "Upstream row reference — e.g. 'DISCUSS#row1' or 'n/a'.",
      "pattern": "^(n/a|[A-Z]+#row[0-9]+)$"
    },
    "DesignDecision": {
      "type": "object",
      "description": "A DDD entry ratifying a design change (E3b, E5 ratification).",
      "required": ["id", "status", "reason"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "Decision identifier — DDD-N pattern.",
          "pattern": "^DDD-[0-9]+$"
        },
        "status": {
          "type": "string",
          "enum": ["accepted", "proposed", "superseded", "deprecated"],
          "description": "Lifecycle status of the decision."
        },
        "reason": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable rationale."
        }
      }
    },
    "DDDEntry": {
      "$ref": "#/definitions/DesignDecision",
      "description": "Alias for DesignDecision — DDDEntry and DesignDecision are the same type."
    }
  },
  "properties": {
    "title": {
      "type": "string",
      "description": "Feature name from the first H1 heading."
    },
    "wave_sections": {
      "type": "array",
      "items": { "$ref": "#/definitions/WaveSection" },
      "description": "Ordered list of wave sections present in the document."
    }
  }
}

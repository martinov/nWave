# Environment Variant: Upgrading from older nWave version with stale artifacts.
#
# Tests that nWave handles upgrade from a previous installation gracefully:
# old hooks dir, old skill layout (nw/ instead of nw-*), orphaned config,
# old DES hooks format in settings.json.
#
# Layer 4 of platform-testing-strategy.md
#
# Build:  docker build --no-cache -f tests/e2e/Dockerfile.env-with-stale-config -t nwave-env-stale .
# Run:    docker run --rm nwave-env-stale

FROM python:3.12-slim

RUN apt-get update && \
    apt-get install -y --no-install-recommends git curl && \
    rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir pipx && \
    pipx ensurepath

RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - && \
    apt-get install -y --no-install-recommends nodejs && \
    rm -rf /var/lib/apt/lists/*

RUN npm install -g @anthropic-ai/claude-code

RUN useradd -m -s /bin/bash dev
USER dev
WORKDIR /home/dev

# --- PRE-EXISTING ENVIRONMENT: stale nWave v2.15.0 artifacts ---

# Old hooks directory with orphaned hook scripts
RUN mkdir -p /home/dev/.nwave/hooks && \
    printf '#!/bin/bash\n# nWave 2.15.0 attribution hook\necho "old-nwave-hook"\n' \
        > /home/dev/.nwave/hooks/pre-commit && \
    chmod +x /home/dev/.nwave/hooks/pre-commit && \
    printf '#!/bin/bash\n# nWave 2.15.0 commit-msg hook\n' \
        > /home/dev/.nwave/hooks/commit-msg && \
    chmod +x /home/dev/.nwave/hooks/commit-msg

# Old global config with v2.x format
RUN mkdir -p /home/dev/.nwave && \
    printf '{\n  "version": "2.15.0",\n  "attribution": {"enabled": true},\n  "hooks": {"global_path": "/home/dev/.nwave/hooks"}\n}\n' \
        > /home/dev/.nwave/global-config.json

# Old skill layout (flat nw/ directory instead of nw-* prefixed)
RUN mkdir -p /home/dev/.claude/skills/nw/software-crafter && \
    echo "# Old TDD methodology v2.15.0" > /home/dev/.claude/skills/nw/software-crafter/tdd-methodology.md && \
    mkdir -p /home/dev/.claude/skills/nw/quality-framework && \
    echo "# Old quality framework v2.15.0" > /home/dev/.claude/skills/nw/quality-framework/SKILL.md

# Old agent layout
RUN mkdir -p /home/dev/.claude/agents/nw && \
    echo "# Old crafter agent v2.15.0" > /home/dev/.claude/agents/nw/crafter.md

# Old DES hooks format in settings.json (simulates pre-v3 hook registration)
RUN mkdir -p /home/dev/.claude && \
    printf '{\n  "hooks": {\n    "pre-tool-use": [{"command": "python -m des.old_hook pre_tool_use"}]\n  }\n}\n' \
        > /home/dev/.claude/settings.json

# Create a test project
RUN git init /home/dev/project && \
    cd /home/dev/project && \
    git config user.email "dev@test.com" && \
    git config user.name "Dev" && \
    echo "# Test" > README.md && \
    git add -A && \
    git commit -m "init" --no-verify

# Install nWave (the NEW version, over stale artifacts)
RUN pipx install nwave-ai

# --- TEST SCRIPT ---
COPY --chown=dev:dev <<'TEST' /home/dev/test.sh
#!/bin/bash
set -o pipefail

PASS=0
FAIL=0

check() {
    local name="$1"
    local condition="$2"
    local detail="${3:-}"
    if eval "$condition"; then
        ((PASS++)) || true
        echo "  [PASS] $name${detail:+ -- $detail}"
    else
        ((FAIL++)) || true
        echo "  [FAIL] $name${detail:+ -- $detail}"
    fi
}

echo ""
echo "============================================================"
echo "  nWave Environment Test: stale config upgrade"
echo "============================================================"
echo ""

# --- Pre-state: verify stale artifacts existed ---
echo "--- Pre-state (stale artifacts were created during build) ---"
echo "  Old hooks dir: ~/.nwave/hooks/ (created in Dockerfile)"
echo "  Old skills dir: ~/.claude/skills/nw/ (created in Dockerfile)"
echo "  Old settings.json: pre-v3 DES hooks (created in Dockerfile)"

echo ""
echo "--- Running nWave install ---"

INSTALL_OUTPUT=$(~/.local/bin/nwave-ai install 2>&1 || true)
INSTALL_EXIT=$?
echo "  Install exit code: $INSTALL_EXIT"
echo "  Install output (last 200 chars): ${INSTALL_OUTPUT: -200}"

check "install completed without error" \
    '[ $INSTALL_EXIT -eq 0 ] || echo "$INSTALL_OUTPUT" | grep -qi "installed\|success\|healthy"'

echo ""
echo "--- Post-install verification ---"

# New skill layout present (nw-* prefixed directories)
check "new nw-* skill layout installed" \
    'ls -d ~/.claude/skills/nw-* >/dev/null 2>&1'

# Old nw/ layout should be cleaned up (or at least not interfere)
# Note: installer may or may not remove old layout, but new must be present
OLD_SKILL_COUNT=$(find ~/.claude/skills/nw/ -name "*.md" 2>/dev/null | wc -l)
NEW_SKILL_COUNT=$(find ~/.claude/skills/nw-* -name "*.md" 2>/dev/null | wc -l)
check "new skills outnumber old stale skills" \
    '[ "$NEW_SKILL_COUNT" -gt "$OLD_SKILL_COUNT" ]' \
    "new=$NEW_SKILL_COUNT, old=$OLD_SKILL_COUNT"

# Agents installed in new layout
check "agents installed" \
    '[ -d ~/.claude/agents/nw ] || ls ~/.claude/agents/nw-* >/dev/null 2>&1'

# Settings.json should have current hooks format (not the old one)
if [ -f ~/.claude/settings.json ]; then
    SETTINGS_CONTENT=$(cat ~/.claude/settings.json)
    check "settings.json exists after install" 'true'
    # New format hooks must be present (des.adapters.drivers.hooks)
    check "new DES hook format present" \
        'echo "$SETTINGS_CONTENT" | grep -q "claude_code_hook_adapter"' \
        "new hook adapter must be in settings.json"
else
    check "settings.json exists after install" 'false' "settings.json missing"
fi

# No duplicate hook entries (old + new both present = duplicate)
if [ -f ~/.claude/settings.json ]; then
    HOOK_ENTRIES=$(python3 -c "
import json
with open('$HOME/.claude/settings.json') as f:
    d = json.load(f)
hooks = d.get('hooks', {})
count = sum(len(v) if isinstance(v, list) else 1 for v in hooks.values())
print(count)
" 2>/dev/null || echo "0")
    check "no duplicate hook entries in settings.json" \
        '[ "$HOOK_ENTRIES" -lt 20 ]' \
        "total hook entries: $HOOK_ENTRIES"
fi

echo ""
echo "============================================================"
echo "  Results: $PASS passed, $FAIL failed"
echo "============================================================"
exit $FAIL
TEST
RUN chmod +x /home/dev/test.sh

CMD ["/home/dev/test.sh"]

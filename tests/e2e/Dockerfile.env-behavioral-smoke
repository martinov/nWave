# Environment Variant: Behavioral smoke test with pre-commit.
#
# THE CRITICAL TEST. Validates that nWave's attribution hook actually fires
# during a real git commit in an environment where pre-commit is installed.
#
# This test would have caught the attribution hook bug (2026-03): hook was
# installed in ~/.nwave/hooks/ but pre-commit's local core.hooksPath shadowed
# the global hooksPath, so git never executed nWave's hook.
#
# Layer 4 of platform-testing-strategy.md
#
# Build:  docker build --no-cache -f tests/e2e/Dockerfile.env-behavioral-smoke -t nwave-env-behavioral .
# Run:    docker run --rm nwave-env-behavioral

FROM python:3.12-slim

RUN apt-get update && \
    apt-get install -y --no-install-recommends git curl && \
    rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir pipx && \
    pipx ensurepath

RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - && \
    apt-get install -y --no-install-recommends nodejs && \
    rm -rf /var/lib/apt/lists/*

RUN npm install -g @anthropic-ai/claude-code

RUN useradd -m -s /bin/bash dev
USER dev
WORKDIR /home/dev

# --- PRE-EXISTING ENVIRONMENT: pre-commit (same as real developer) ---

# Install pre-commit
RUN pip install --user pre-commit==3.6.0

# Create project with pre-commit installed (sets core.hooksPath)
RUN git init /home/dev/project && \
    cd /home/dev/project && \
    git config user.email "dev@test.com" && \
    git config user.name "Dev" && \
    printf 'repos:\n  - repo: local\n    hooks:\n      - id: trailing-ws\n        name: trailing whitespace\n        entry: "true"\n        language: system\n        types: [text]\n' > .pre-commit-config.yaml && \
    ~/.local/bin/pre-commit install && \
    echo "# Test project" > README.md && \
    git add -A && \
    git commit -m "init" --no-verify

# Enable attribution in nWave config BEFORE install
RUN mkdir -p /home/dev/.nwave && \
    printf '{"attribution": {"enabled": true, "trailer": "Co-Authored-By: nWave <nwave@nwave.ai>"}}\n' > /home/dev/.nwave/global-config.json

# Create minimal Claude Code environment (required by nwave-ai install)
RUN mkdir -p /home/dev/.claude && \
    printf '{"permissions": {}, "hooks": {}}\n' > /home/dev/.claude/settings.json

# Install nwave-ai from PyPI for the CLI + installer framework
RUN python3 -m venv /home/dev/.venv && \
    /home/dev/.venv/bin/pip install --pre nwave-ai

# Patch: overwrite BOTH attribution files with local fixes
COPY --chown=dev:dev scripts/install/attribution_utils.py /tmp/patch/
COPY --chown=dev:dev scripts/install/plugins/attribution_plugin.py /tmp/patch/
RUN find /home/dev/.venv -name "attribution_utils.py" -path "*/install/*" \
        -exec cp /tmp/patch/attribution_utils.py {} \; -exec echo "Patched utils: {}" \; && \
    find /home/dev/.venv -name "attribution_plugin.py" -path "*/plugins/*" \
        -exec cp /tmp/patch/attribution_plugin.py {} \; -exec echo "Patched plugin: {}" \;

# Run nWave installer inside the project directory (in venv)
RUN cd /home/dev/project && \
    /home/dev/.venv/bin/nwave-ai install 2>&1 || echo "Install exited with $?"

# Ensure attribution hook is installed in the project's hooks dir
# (the installer may not resolve the project's git dir correctly during Docker build)
RUN cd /home/dev/project && \
    /home/dev/.venv/bin/python -c "from scripts.install.attribution_utils import install_attribution_hook; install_attribution_hook()" 2>&1

# --- TEST SCRIPT ---
COPY --chown=dev:dev <<'TEST' /home/dev/test.sh
#!/bin/bash
set -eo pipefail

PASS=0
FAIL=0

check() {
    local name="$1"
    local condition="$2"
    local detail="${3:-}"
    if eval "$condition"; then
        ((PASS++)) || true
        echo "  [PASS] $name${detail:+ -- $detail}"
    else
        ((FAIL++)) || true
        echo "  [FAIL] $name${detail:+ -- $detail}"
    fi
}

echo ""
echo "============================================================"
echo "  nWave Environment Test: behavioral smoke (CRITICAL)"
echo "============================================================"
echo ""

PROJECT=/home/dev/project
cd "$PROJECT"

# --- Pre-state: confirm pre-commit is active ---
echo "--- Pre-state verification ---"

check "pre-commit hook script exists in .git/hooks/" \
    '[ -f "$PROJECT/.git/hooks/pre-commit" ]'

HOOKS_PATH=$(git config --get core.hooksPath 2>/dev/null || echo ".git/hooks")
echo "  core.hooksPath: ${HOOKS_PATH:-.git/hooks (default)}"

echo ""
echo "--- Running nWave install ---"

export PATH="$HOME/.local/bin:$PATH"
echo "  Install already ran during Docker build"

echo ""
echo "--- Post-install hook inspection ---"

# Show where hooks are installed (diagnostic)
echo "  Global hooksPath: $(git config --global --get core.hooksPath 2>/dev/null || echo 'not set')"
echo "  Local hooksPath: $(git config --local --get core.hooksPath 2>/dev/null || echo 'not set')"
echo "  Effective hooksPath: $(git config --get core.hooksPath 2>/dev/null || echo 'not set')"

# List hooks in effective hooks directory
EFFECTIVE_HOOKS=$(git config --get core.hooksPath 2>/dev/null || echo ".git/hooks")
echo "  Hooks in effective dir ($EFFECTIVE_HOOKS):"
ls -la "$PROJECT/$EFFECTIVE_HOOKS/" 2>/dev/null || ls -la "$EFFECTIVE_HOOKS/" 2>/dev/null || echo "    (dir not found)"

# List nWave hooks directory
echo "  Hooks in ~/.nwave/hooks/:"
ls -la ~/.nwave/hooks/ 2>/dev/null || echo "    (dir not found)"

# --- BEHAVIORAL TEST: make a real git commit ---
echo ""
echo "--- Behavioral test: real git commit ---"

# Use --allow-empty so we don't need real file changes
COMMIT_OUTPUT=$(git commit --allow-empty -m "test: behavioral smoke commit" 2>&1 || true)
COMMIT_EXIT=$?
echo "  Commit exit code: $COMMIT_EXIT"
echo "  Commit output: $COMMIT_OUTPUT"

check "git commit succeeds" \
    '[ $COMMIT_EXIT -eq 0 ]'

# Check the commit message for nWave attribution trailer
COMMIT_MSG=$(git log -1 --format=%B 2>/dev/null || echo "")
echo ""
echo "  Full commit message:"
echo "  ---"
echo "  $COMMIT_MSG"
echo "  ---"

# The attribution hook should add "Co-Authored-By: nWave" or similar trailer
check "commit message contains nWave attribution trailer" \
    'echo "$COMMIT_MSG" | grep -qi "nwave\|co-authored-by"' \
    "This is the test that catches the attribution hook bug"

# --- Verify pre-commit hooks also ran ---
echo ""
echo "--- Pre-commit coexistence verification ---"

# Make a commit with a real file to trigger pre-commit hooks
echo "smoke test content" > "$PROJECT/smoke-file.txt"
git add smoke-file.txt
PRECOMMIT_OUTPUT=$(git commit -m "test: pre-commit coexistence" 2>&1 || true)
PRECOMMIT_EXIT=$?
echo "  Pre-commit commit output: $PRECOMMIT_OUTPUT"

check "commit with pre-commit hooks succeeds" \
    '[ $PRECOMMIT_EXIT -eq 0 ]'

# Verify pre-commit ACTUALLY RAN by checking output contains hook name
# If core.hooksPath was overridden, pre-commit won't run and output won't contain hook names
check "pre-commit hooks actually executed (not just skipped)" \
    'echo "$PRECOMMIT_OUTPUT" | grep -qi "trailing whitespace\|Passed\|Failed"' \
    "pre-commit output must show hook execution, not silent skip"

# Verify the second commit also has attribution
COMMIT_MSG2=$(git log -1 --format=%B 2>/dev/null || echo "")
check "second commit also has nWave attribution" \
    'echo "$COMMIT_MSG2" | grep -qi "nwave\|co-authored-by"' \
    "attribution must work on every commit"

echo ""
echo "============================================================"
echo "  Results: $PASS passed, $FAIL failed"
echo "============================================================"

if [ "$FAIL" -gt 0 ]; then
    echo ""
    echo "  NOTE: If 'nWave attribution trailer' tests failed, this"
    echo "  confirms the attribution hook bug: hook is installed but"
    echo "  not executed because pre-commit's core.hooksPath shadows"
    echo "  the global hooksPath where nWave installs its hooks."
    echo ""
fi

exit $FAIL
TEST
RUN chmod +x /home/dev/test.sh

CMD ["/home/dev/test.sh"]

# Environment Variant: Developer with pre-commit already installed.
#
# Tests that nWave installation coexists with pre-commit without breaking
# either tool. pre-commit sets core.hooksPath in local git config, which
# shadows global hooksPath -- the #1 cause of "works in Docker, fails for
# real users" (attribution hook incident, 2026-03).
#
# Layer 4 of platform-testing-strategy.md
#
# Build:  docker build --no-cache -f tests/e2e/Dockerfile.env-with-precommit -t nwave-env-precommit .
# Run:    docker run --rm nwave-env-precommit

FROM python:3.12-slim

RUN apt-get update && \
    apt-get install -y --no-install-recommends git curl && \
    rm -rf /var/lib/apt/lists/*

# Install pipx for nWave installation
RUN pip install --no-cache-dir pipx && \
    pipx ensurepath

# Install Node.js (required for Claude Code / nWave CLI install)
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - && \
    apt-get install -y --no-install-recommends nodejs && \
    rm -rf /var/lib/apt/lists/*

# Install Claude Code (nWave depends on it)
RUN npm install -g @anthropic-ai/claude-code

# Create non-root test user
RUN useradd -m -s /bin/bash dev
USER dev
WORKDIR /home/dev

# --- PRE-EXISTING ENVIRONMENT: pre-commit ---

# Install pre-commit (the real tool)
RUN pip install --user pre-commit==3.6.0

# Create a git repo with pre-commit configured and installed
RUN git init /home/dev/project && \
    cd /home/dev/project && \
    git config user.email "dev@test.com" && \
    git config user.name "Dev" && \
    printf 'repos:\n  - repo: local\n    hooks:\n      - id: trailing-ws\n        name: trailing whitespace\n        entry: "true"\n        language: system\n        types: [text]\n' > .pre-commit-config.yaml && \
    ~/.local/bin/pre-commit install && \
    echo "# Test project" > README.md && \
    git add -A && \
    git commit -m "init" --no-verify

# Install nWave from PyPI
RUN pipx install nwave-ai

# --- TEST SCRIPT ---
COPY --chown=dev:dev <<'TEST' /home/dev/test.sh
#!/bin/bash
set -eo pipefail

PASS=0
FAIL=0

check() {
    local name="$1"
    local condition="$2"
    local detail="${3:-}"
    if eval "$condition"; then
        ((PASS++)) || true
        echo "  [PASS] $name${detail:+ -- $detail}"
    else
        ((FAIL++)) || true
        echo "  [FAIL] $name${detail:+ -- $detail}"
    fi
}

echo ""
echo "============================================================"
echo "  nWave Environment Test: pre-commit coexistence"
echo "============================================================"
echo ""

PROJECT=/home/dev/project
cd "$PROJECT"

# --- Pre-state: verify pre-commit is active ---
echo "--- Pre-state verification ---"

check "pre-commit hook script exists in .git/hooks/" \
    '[ -f "$PROJECT/.git/hooks/pre-commit" ]'

echo ""
echo "--- Running nWave install ---"

# Run nWave install
INSTALL_OUTPUT=$(~/.local/bin/nwave-ai install 2>&1 || true)
echo "  Install output (last 200 chars): ${INSTALL_OUTPUT: -200}"

echo ""
echo "--- Post-install verification ---"

# Verify nWave installed its artifacts
check "nWave skills installed" \
    'ls ~/.claude/skills/nw-* >/dev/null 2>&1'

# Verify pre-commit hook NOT deleted by nWave
check "pre-commit hook preserved (not deleted)" \
    '[ -f "$PROJECT/.git/hooks/pre-commit" ]' \
    "nWave must chain, not replace"

# Verify nWave did NOT set global core.hooksPath (coexistence fix)
GLOBAL_HP=$(git config --global --get core.hooksPath 2>/dev/null || echo "")
check "nWave did not set global core.hooksPath" \
    '[ -z "$GLOBAL_HP" ]' \
    "global hooksPath should be empty, got: $GLOBAL_HP"

# Verify no duplicate hooks (nWave should not install a second pre-commit hook
# in .git/hooks/ if one already exists from pre-commit tool)
HOOK_COUNT=$(find "$PROJECT/.git/hooks" -name "pre-commit*" -not -name "*.sample" 2>/dev/null | wc -l)
check "no duplicate pre-commit hooks" \
    '[ "$HOOK_COUNT" -le 2 ]' \
    "found $HOOK_COUNT pre-commit hook files"

echo ""
echo "============================================================"
echo "  Results: $PASS passed, $FAIL failed"
echo "============================================================"
exit $FAIL
TEST
RUN chmod +x /home/dev/test.sh

CMD ["/home/dev/test.sh"]

# Environment Variant: Plugin marketplace install simulation.
#
# Validates the plugin structure built by build_plugin.py matches what
# Claude Code expects from a marketplace plugin: hooks.json with all
# event types, agents, skills, and functional DES hooks.
#
# This test exercises the "plugin install" path where pip/pipx are NOT
# used and $HOME may be empty (known bug #24529).
#
# Layer 4 of platform-testing-strategy.md
#
# Build:  docker build --no-cache -f tests/e2e/Dockerfile.env-plugin-marketplace -t nwave-env-plugin-marketplace .
# Run:    docker run --rm nwave-env-plugin-marketplace

FROM python:3.12-slim

WORKDIR /build
COPY scripts/build_plugin.py scripts/build_plugin.py
COPY scripts/shared/ scripts/shared/
COPY src/des/ src/des/
COPY nWave/ nWave/
COPY pyproject.toml pyproject.toml

RUN pip install --quiet pyyaml

# Build the plugin
RUN python scripts/build_plugin.py --output-dir /tmp/plugin 2>/dev/null; \
    echo "Plugin build exit: $?"

# Simulate Claude Code plugin cache installation
RUN mkdir -p /root/.claude/plugins/cache/nwave-marketplace/nw/latest && \
    cp -r /tmp/plugin/* /root/.claude/plugins/cache/nwave-marketplace/nw/latest/

# Write the test script (uses BuildKit COPY heredoc, not shell heredoc,
# to avoid Docker parsing Python code as Dockerfile instructions)
COPY <<'PYEOF' /tmp/test_plugin_marketplace.py
"""Plugin marketplace install smoke test.

Validates:
1. hooks.json has all expected event types
2. Agent files present in plugin dir
3. Skill files accessible
4. DES hooks functional (call hook adapter with mock input)
5. Works without $HOME set (plugin env bug)
"""
import json
import os
import subprocess
import sys
from pathlib import Path

RESULTS = []
TOTAL = 0
FAILED = 0

PLUGIN_ROOT = "/root/.claude/plugins/cache/nwave-marketplace/nw/latest"


def test(name, condition, detail=""):
    global TOTAL, FAILED
    TOTAL += 1
    if condition:
        RESULTS.append(("PASS", name, detail))
    else:
        FAILED += 1
        RESULTS.append(("FAIL", name, detail))


# --- 1. hooks.json structure ---

hooks_path = Path(PLUGIN_ROOT) / "hooks" / "hooks.json"
test("hooks.json exists", hooks_path.exists())

if hooks_path.exists():
    raw = json.loads(hooks_path.read_text())

    # hooks.json uses envelope: {"hooks": {"EventName": [...]}}
    test("hooks.json has 'hooks' envelope key", "hooks" in raw)
    hooks = raw.get("hooks", {})

    # Expected event types from hook_definitions.py
    expected_events = {"PreToolUse", "PostToolUse", "SubagentStop", "SessionStart", "SubagentStart"}
    actual_events = set(hooks.keys())
    test(
        "hooks.json has all 5 event types",
        expected_events.issubset(actual_events),
        f"expected={sorted(expected_events)}, actual={sorted(actual_events)}",
    )

    # Check PreToolUse has Agent, Write, Edit, Bash matchers
    pre_tool_use = hooks.get("PreToolUse", [])
    matchers = {entry.get("matcher") for entry in pre_tool_use}
    expected_matchers = {"Agent", "Write", "Edit", "Bash"}
    test(
        "PreToolUse has Agent/Write/Edit/Bash matchers",
        expected_matchers.issubset(matchers),
        f"expected={sorted(expected_matchers)}, actual={sorted(m for m in matchers if m)}",
    )

    # Check each hook entry has proper nested format
    all_have_hooks = all(
        "hooks" in entry
        for event_hooks in hooks.values()
        for entry in event_hooks
    )
    test("all hook entries use nested format", all_have_hooks)

    # Check commands reference the hook adapter
    adapter_refs = 0
    shell_refs = 0
    for event_hooks in hooks.values():
        for entry in event_hooks:
            for h in entry.get("hooks", []):
                cmd = h.get("command", "")
                if "claude_code_hook_adapter" in cmd:
                    adapter_refs += 1
                elif "des-hook:" in cmd:
                    shell_refs += 1
    test(
        "hook commands reference adapter or shell guard",
        adapter_refs > 0,
        f"adapter_refs={adapter_refs}, shell_refs={shell_refs}",
    )


# --- 2. Agent files ---

agents_dir = Path(PLUGIN_ROOT) / "agents"
test("agents directory exists", agents_dir.exists())

if agents_dir.exists():
    agent_files = list(agents_dir.glob("nw-*.md"))
    test("agent files present", len(agent_files) > 10, f"{len(agent_files)} agents")

    # Spot-check: software-crafter should exist
    crafter = agents_dir / "nw-software-crafter.md"
    test("nw-software-crafter.md exists", crafter.exists())


# --- 3. Skill files ---

skills_dir = Path(PLUGIN_ROOT) / "skills"
test("skills directory exists", skills_dir.exists())

if skills_dir.exists():
    skill_dirs = [d for d in skills_dir.iterdir() if d.is_dir()]
    test("skill directories present", len(skill_dirs) > 30, f"{len(skill_dirs)} skills")

    # Spot-check: each skill dir should have SKILL.md
    skills_with_md = [d for d in skill_dirs if (d / "SKILL.md").exists()]
    test(
        "all skill dirs have SKILL.md",
        len(skills_with_md) == len(skill_dirs),
        f"{len(skills_with_md)}/{len(skill_dirs)}",
    )


# --- 4. DES module accessible ---

des_dir = Path(PLUGIN_ROOT) / "scripts" / "des"
test("DES module directory exists", des_dir.exists())

if des_dir.exists():
    init_file = des_dir / "__init__.py"
    test("DES __init__.py exists", init_file.exists())

    adapter_file = des_dir / "adapters" / "drivers" / "hooks" / "claude_code_hook_adapter.py"
    test("hook adapter exists", adapter_file.exists())


# --- 5. DES hooks functional (with CLAUDE_PLUGIN_ROOT) ---

DISCOVERY = (
    "import os,sys;"
    "from pathlib import Path;"
    "r=os.environ.get('CLAUDE_PLUGIN_ROOT','');"
    "p=r+'/scripts' if r else '';"
    "p=p or next((str(s) for s in sorted("
    "Path.home().joinpath('.claude/plugins/cache').glob('*/nw/*/scripts'))"
    " if (s/'des'/'__init__.py').exists()),None);"
    "p=p or str(Path.home()/'.claude/lib/python');"
    "sys.path.insert(0,p);"
    "sys.argv=['des-hook','{action}'];"
    "from des.adapters.drivers.hooks.claude_code_hook_adapter import main;"
    "main()"
)

# Test with CLAUDE_PLUGIN_ROOT set (happy path)
env_with = os.environ.copy()
env_with["CLAUDE_PLUGIN_ROOT"] = PLUGIN_ROOT
r = subprocess.run(
    ["python3", "-c", DISCOVERY.format(action="pre-task")],
    input='{"tool_input":{"prompt":"test"}}',
    capture_output=True, text=True, env=env_with,
)
test(
    "DES hook functional with CLAUDE_PLUGIN_ROOT",
    r.returncode == 0,
    f"exit={r.returncode}, err={r.stderr[:100]}" if r.returncode != 0 else "ok",
)

# Test without CLAUDE_PLUGIN_ROOT (fallback discovery)
env_without = os.environ.copy()
env_without.pop("CLAUDE_PLUGIN_ROOT", None)
r = subprocess.run(
    ["python3", "-c", DISCOVERY.format(action="pre-task")],
    input='{"tool_input":{"prompt":"test"}}',
    capture_output=True, text=True, env=env_without,
)
test(
    "DES hook functional without CLAUDE_PLUGIN_ROOT (fallback)",
    r.returncode == 0,
    f"exit={r.returncode}, err={r.stderr[:100]}" if r.returncode != 0 else "ok",
)


# --- 6. Works without $HOME (plugin env bug simulation) ---

env_no_home = os.environ.copy()
env_no_home.pop("HOME", None)
env_no_home["CLAUDE_PLUGIN_ROOT"] = PLUGIN_ROOT
r = subprocess.run(
    ["python3", "-c", DISCOVERY.format(action="session-start")],
    input="{}",
    capture_output=True, text=True, env=env_no_home,
)
# This tests the known bug: $HOME empty in plugin hook env.
# With CLAUDE_PLUGIN_ROOT set, hooks should still work.
test(
    "DES hook works without $HOME (CLAUDE_PLUGIN_ROOT set)",
    r.returncode == 0,
    f"exit={r.returncode}, err={r.stderr[:100]}" if r.returncode != 0 else "ok",
)


# --- Report ---
print()
print("=" * 70)
print("PLUGIN MARKETPLACE INSTALL SMOKE TEST")
print("=" * 70)
for status, name, detail in RESULTS:
    icon = "PASS" if status == "PASS" else "FAIL"
    line = f"  [{icon}] {name}"
    if detail:
        line += f" -- {detail[:80]}"
    print(line)
print("=" * 70)
print(f"TOTAL: {TOTAL} tests, {TOTAL - FAILED} passed, {FAILED} failed")
if FAILED == 0:
    print("ALL TESTS PASSED")
else:
    print(f"{FAILED} TESTS FAILED")
sys.exit(0 if FAILED == 0 else 1)
PYEOF

CMD ["python3", "/tmp/test_plugin_marketplace.py"]

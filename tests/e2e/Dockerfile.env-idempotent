# Environment Variant: Idempotent installation verification.
#
# Installs nWave TWICE. Verifies second install produces no meaningful
# changes: no duplicate hooks, no duplicate config entries, no extra files.
# Only timestamps may differ.
#
# Layer 4 of platform-testing-strategy.md
#
# Build:  docker build --no-cache -f tests/e2e/Dockerfile.env-idempotent -t nwave-env-idempotent .
# Run:    docker run --rm nwave-env-idempotent

FROM python:3.12-slim

RUN apt-get update && \
    apt-get install -y --no-install-recommends git curl && \
    rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir pipx && \
    pipx ensurepath

RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - && \
    apt-get install -y --no-install-recommends nodejs && \
    rm -rf /var/lib/apt/lists/*

RUN npm install -g @anthropic-ai/claude-code

RUN useradd -m -s /bin/bash dev
USER dev
WORKDIR /home/dev

# Create a test project
RUN git init /home/dev/project && \
    cd /home/dev/project && \
    git config user.email "dev@test.com" && \
    git config user.name "Dev" && \
    echo "# Test" > README.md && \
    git add -A && \
    git commit -m "init" --no-verify

# Install nWave from PyPI
RUN pipx install nwave-ai

# --- TEST SCRIPT ---
COPY --chown=dev:dev <<'TEST' /home/dev/test.sh
#!/bin/bash
set -eo pipefail

PASS=0
FAIL=0

check() {
    local name="$1"
    local condition="$2"
    local detail="${3:-}"
    if eval "$condition"; then
        ((PASS++)) || true
        echo "  [PASS] $name${detail:+ -- $detail}"
    else
        ((FAIL++)) || true
        echo "  [FAIL] $name${detail:+ -- $detail}"
    fi
}

snapshot() {
    # Capture a content-based snapshot of nWave artifacts.
    # Excludes timestamps (only file names and content hashes).
    local label="$1"
    local output="$2"

    {
        # File listing (sorted, no timestamps)
        echo "=== FILES ==="
        find ~/.claude/skills/nw-* ~/.claude/agents/ ~/.claude/settings.json \
            ~/.nwave/ 2>/dev/null | sort

        # Content hashes of key files
        echo "=== CONTENT HASHES ==="
        find ~/.claude/skills/nw-* -type f 2>/dev/null | sort | \
            xargs md5sum 2>/dev/null || true
        md5sum ~/.claude/settings.json 2>/dev/null || true

        # Settings.json hook count
        echo "=== HOOK COUNT ==="
        python3 -c "
import json, pathlib
p = pathlib.Path.home() / '.claude' / 'settings.json'
if p.exists():
    d = json.loads(p.read_text())
    hooks = d.get('hooks', {})
    for event, entries in sorted(hooks.items()):
        count = len(entries) if isinstance(entries, list) else 1
        print(f'{event}: {count}')
" 2>/dev/null || echo "(no settings.json)"

    } > "$output"

    echo "  Snapshot '$label' captured: $(wc -l < "$output") lines"
}

echo ""
echo "============================================================"
echo "  nWave Environment Test: idempotent installation"
echo "============================================================"
echo ""

# --- First install ---
echo "--- First install ---"
INSTALL1_OUTPUT=$(~/.local/bin/nwave-ai install 2>&1 || true)
INSTALL1_EXIT=$?
echo "  Exit code: $INSTALL1_EXIT"
echo "  Output (last 150 chars): ${INSTALL1_OUTPUT: -150}"

check "first install succeeds" \
    '[ $INSTALL1_EXIT -eq 0 ] || echo "$INSTALL1_OUTPUT" | grep -qi "installed\|success\|healthy"'

echo ""
echo "--- Capturing first snapshot ---"
snapshot "after-install-1" /tmp/snapshot1.txt

# --- Second install ---
echo ""
echo "--- Second install (must be idempotent) ---"
INSTALL2_OUTPUT=$(~/.local/bin/nwave-ai install 2>&1 || true)
INSTALL2_EXIT=$?
echo "  Exit code: $INSTALL2_EXIT"
echo "  Output (last 150 chars): ${INSTALL2_OUTPUT: -150}"

check "second install succeeds" \
    '[ $INSTALL2_EXIT -eq 0 ] || echo "$INSTALL2_OUTPUT" | grep -qi "installed\|success\|healthy"'

echo ""
echo "--- Capturing second snapshot ---"
snapshot "after-install-2" /tmp/snapshot2.txt

# --- Diff snapshots ---
echo ""
echo "--- Comparing snapshots ---"

DIFF_OUTPUT=$(diff /tmp/snapshot1.txt /tmp/snapshot2.txt 2>&1 || true)
if [ -z "$DIFF_OUTPUT" ]; then
    echo "  Snapshots are identical (perfect idempotence)"
    check "snapshots identical after second install" 'true'
else
    echo "  Diff found:"
    echo "$DIFF_OUTPUT" | head -20
    # Allow minor diffs (e.g., log files) but flag structural changes
    STRUCTURAL_DIFFS=$(echo "$DIFF_OUTPUT" | grep -c "^[<>]" || true)
    check "no structural differences after second install" \
        '[ "$STRUCTURAL_DIFFS" -le 5 ]' \
        "$STRUCTURAL_DIFFS structural diff lines"
fi

# --- Duplicate checks ---
echo ""
echo "--- Duplicate entry checks ---"

# No duplicate hooks in settings.json
if [ -f ~/.claude/settings.json ]; then
    DUPLICATE_HOOKS=$(python3 -c "
import json, pathlib
p = pathlib.Path.home() / '.claude' / 'settings.json'
d = json.loads(p.read_text())
hooks = d.get('hooks', {})
duplicates = 0
for event, entries in hooks.items():
    if isinstance(entries, list):
        # Extract command from both flat and nested formats
        commands = []
        for e in entries:
            if 'command' in e and e['command']:
                commands.append(e['command'])
            elif 'hooks' in e:
                for h in e['hooks']:
                    if h.get('command'):
                        commands.append(h['command'])
        if len(commands) != len(set(commands)):
            duplicates += len(commands) - len(set(commands))
print(duplicates)
" 2>/dev/null || echo "0")
    check "no duplicate hook commands in settings.json" \
        '[ "$DUPLICATE_HOOKS" -eq 0 ]' \
        "$DUPLICATE_HOOKS duplicates found"
fi

# No duplicate skill directories
SKILL_DIRS=$(ls -d ~/.claude/skills/nw-* 2>/dev/null | sort)
UNIQUE_SKILL_DIRS=$(echo "$SKILL_DIRS" | sort -u)
check "no duplicate skill directories" \
    '[ "$(echo "$SKILL_DIRS" | wc -l)" -eq "$(echo "$UNIQUE_SKILL_DIRS" | wc -l)" ]'

echo ""
echo "============================================================"
echo "  Results: $PASS passed, $FAIL failed"
echo "============================================================"
exit $FAIL
TEST
RUN chmod +x /home/dev/test.sh

CMD ["/home/dev/test.sh"]

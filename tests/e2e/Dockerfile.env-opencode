# Environment Variant: OpenCode CLI install simulation.
#
# Validates that nWave installer detects OpenCode configuration and
# installs skills, agents, and commands to the correct OpenCode paths
# with proper format transformations (no Claude Code-only frontmatter,
# correct permission format, rewritten skill paths).
#
# Layer 4 of platform-testing-strategy.md
#
# Build:  docker build --no-cache -f tests/e2e/Dockerfile.env-opencode -t nwave-env-opencode .
# Run:    docker run --rm nwave-env-opencode

FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends git curl && \
    curl -fsSL https://deb.nodesource.com/setup_22.x | bash - && \
    apt-get install -y --no-install-recommends nodejs && \
    rm -rf /var/lib/apt/lists/*

# Install OpenCode
RUN npm install -g opencode-ai

RUN useradd -m tester
USER tester
WORKDIR /home/tester

COPY --chown=tester:tester . /home/tester/nwave-dev/

# Configure OpenCode (triggers OpenCode detection in installer)
RUN mkdir -p /home/tester/.config/opencode && \
    echo '{"model": "openai/gpt-4o-mini"}' > /home/tester/.config/opencode/opencode.json

# Uses BuildKit COPY heredoc to avoid Docker parsing Python code
# (e.g., `env = os.environ.copy()`) as Dockerfile instructions
COPY --chown=tester:tester <<'PYEOF' /home/tester/test_opencode_install.py
"""OpenCode install smoke test.

Validates:
1. Skills installed at ~/.config/opencode/skills/
2. Agents installed at ~/.config/opencode/agents/
3. No Claude Code-only frontmatter fields in installed skills
4. Agent permission format uses "allow" strings, not booleans
5. Skill paths rewritten from ~/.claude/ to ~/.config/opencode/
6. Manifests present and valid
"""
import json
import os
import re
import subprocess
import sys
from pathlib import Path

RESULTS = []
TOTAL = 0
FAILED = 0


def test(name, condition, detail=""):
    global TOTAL, FAILED
    TOTAL += 1
    if condition:
        RESULTS.append(("PASS", name, detail))
    else:
        FAILED += 1
        RESULTS.append(("FAIL", name, detail))


def run(cmd, **kw):
    return subprocess.run(cmd, shell=True, capture_output=True, text=True, **kw)


os.chdir("/home/tester/nwave-dev")

# Create venv and install dependencies
run("python -m venv /tmp/venv && /tmp/venv/bin/pip install pyyaml -q")
env = os.environ.copy()
env["VIRTUAL_ENV"] = "/tmp/venv"
env["PATH"] = "/tmp/venv/bin:" + env["PATH"]

# Run installer (detects OpenCode config -> installs to OpenCode paths)
r = run("python scripts/install/install_nwave.py", env=env)
# Check for core component installation markers rather than the final
# summary line, which requires 100% plugin success (including optional
# plugins like attribution that may fail on Logger API mismatches).
core_markers = [
    "Skills installed",
    "Agents installed",
    "DES module",
    "Settings updated",
]
markers_found = sum(1 for m in core_markers if m in r.stdout)
install_ok = markers_found >= 3
test(
    "install succeeds (core components)",
    install_ok,
    f"{markers_found}/{len(core_markers)} markers"
    if install_ok
    else r.stdout[-300:],
)

home = Path.home()

# --- 1. OpenCode skills ---

oc_skills = home / ".config" / "opencode" / "skills"
test("skills directory exists", oc_skills.exists())

if oc_skills.exists():
    dirs = [d for d in oc_skills.iterdir() if d.is_dir()]
    test("skills populated", len(dirs) > 50, f"{len(dirs)} skill dirs")

    # Check SKILL.md format
    with_skillmd = [d for d in dirs if (d / "SKILL.md").exists()]
    test(
        "all skill dirs have SKILL.md",
        len(with_skillmd) == len(dirs),
        f"{len(with_skillmd)}/{len(dirs)}",
    )

    # Check manifest
    manifest = oc_skills / ".nwave-manifest.json"
    if manifest.exists():
        mdata = json.loads(manifest.read_text())
        test("skills manifest present", "installed_skills" in mdata,
             f"{len(mdata.get('installed_skills', []))} tracked")
        test("skills manifest version", mdata.get("version") == "1.0")
    else:
        test("skills manifest present", False, "missing")

    # --- Forbidden fields check ---
    # Claude Code-only fields must be stripped
    FORBIDDEN = {"user-invocable", "disable-model-invocation"}
    forbidden_found = []
    for d in dirs[:20]:  # Sample first 20
        sm = d / "SKILL.md"
        if not sm.exists():
            continue
        content = sm.read_text()
        if not content.startswith("---"):
            continue
        try:
            end_idx = content.index("---", 3)
            frontmatter = content[4:end_idx]
        except ValueError:
            continue
        for field in FORBIDDEN:
            if f"{field}:" in frontmatter:
                forbidden_found.append(f"{d.name}/{field}")

    test(
        "no Claude Code-only frontmatter in skills",
        len(forbidden_found) == 0,
        f"found: {forbidden_found[:5]}" if forbidden_found else "clean",
    )


# --- 2. OpenCode agents ---

oc_agents = home / ".config" / "opencode" / "agents"
test("agents directory exists", oc_agents.exists())

if oc_agents.exists():
    agent_files = list(oc_agents.glob("nw-*.md"))
    test("agents installed", len(agent_files) > 10, f"{len(agent_files)} agents")

    # Check manifest
    manifest = oc_agents / ".nwave-agents-manifest.json"
    if manifest.exists():
        mdata = json.loads(manifest.read_text())
        test("agents manifest present", "installed_agents" in mdata,
             f"{len(mdata.get('installed_agents', []))} tracked")
    else:
        test("agents manifest present", False, "missing")

    # --- Permission format check ---
    # OpenCode uses {"permission": {"tool": "allow"}} not tools: CSV
    permission_ok = 0
    permission_bad = 0
    for af in agent_files[:10]:  # Sample first 10
        content = af.read_text()
        if not content.startswith("---"):
            continue
        try:
            end_idx = content.index("---", 3)
            frontmatter = content[4:end_idx]
        except ValueError:
            continue
        # Should NOT have "tools:" as CSV string
        if re.search(r'^tools:\s*"', frontmatter, re.MULTILINE):
            permission_bad += 1
        # Should have mode: subagent
        if "mode: subagent" in frontmatter:
            permission_ok += 1

    test(
        "agents have mode: subagent",
        permission_ok > 0,
        f"{permission_ok} agents with mode: subagent",
    )
    test(
        "agents do not have tools: CSV format",
        permission_bad == 0,
        f"{permission_bad} agents with bad format" if permission_bad else "clean",
    )

    # --- No Claude Code-only fields in agents ---
    AGENT_FORBIDDEN = {"name", "model", "skills"}
    agent_forbidden_found = []
    for af in agent_files[:10]:
        content = af.read_text()
        if not content.startswith("---"):
            continue
        try:
            end_idx = content.index("---", 3)
            frontmatter = content[4:end_idx]
        except ValueError:
            continue
        for field in AGENT_FORBIDDEN:
            if re.match(rf'^{field}:\s', frontmatter, re.MULTILINE):
                agent_forbidden_found.append(f"{af.name}/{field}")

    test(
        "no Claude Code-only fields in agents (name/model/skills)",
        len(agent_forbidden_found) == 0,
        f"found: {agent_forbidden_found[:5]}" if agent_forbidden_found else "clean",
    )

    # --- Skill path rewriting ---
    # Agent bodies should reference ~/.config/opencode/skills/ not ~/.claude/skills/
    claude_path_refs = []
    for af in agent_files[:10]:
        content = af.read_text()
        if "~/.claude/skills/" in content:
            claude_path_refs.append(af.name)

    test(
        "skill paths rewritten in agent bodies",
        len(claude_path_refs) == 0,
        f"still has ~/.claude/skills/: {claude_path_refs[:5]}" if claude_path_refs else "clean",
    )


# --- 3. OpenCode commands ---

oc_cmds = home / ".config" / "opencode" / "commands"
if oc_cmds.exists():
    cmd_files = list(oc_cmds.rglob("*.md"))
    test("commands installed", len(cmd_files) > 0, f"{len(cmd_files)} commands")
else:
    test("commands directory exists", False)


# --- 4. Claude Code skills also installed ---

cc_skills = home / ".claude" / "skills"
nw_skills = [d for d in cc_skills.iterdir() if d.is_dir() and d.name.startswith("nw-")] if cc_skills.exists() else []
test("Claude Code skills also installed", len(nw_skills) > 50, f"{len(nw_skills)} skills")


# --- Report ---
print("\n" + "=" * 70)
print("OPENCODE INSTALL SMOKE TEST")
print("=" * 70)
for status, name, detail in RESULTS:
    icon = "PASS" if status == "PASS" else "FAIL"
    line = f"  [{icon}] {name}"
    if detail:
        line += f" -- {detail[:80]}"
    print(line)
print("=" * 70)
print(f"TOTAL: {TOTAL} tests, {TOTAL - FAILED} passed, {FAILED} failed")
if FAILED == 0:
    print("ALL TESTS PASSED")
else:
    print(f"{FAILED} TESTS FAILED")
sys.exit(0 if FAILED == 0 else 1)
PYEOF

CMD ["python", "/home/tester/test_opencode_install.py"]

FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends git && rm -rf /var/lib/apt/lists/*
RUN useradd -m tester
USER tester
WORKDIR /home/tester

COPY --chown=tester:tester . /home/tester/nwave-dev/

RUN cat > /home/tester/test_contract_validation.py << 'PYEOF'
"""Verify cross-platform contract validation fixes (5 anomalies + CI gate)."""
import json
import os
import re
import subprocess
import sys
from pathlib import Path

RESULTS = []
TOTAL = 0
FAILED = 0

def test(name, condition, detail=""):
    global TOTAL, FAILED
    TOTAL += 1
    if condition:
        RESULTS.append(("PASS", name, detail))
    else:
        FAILED += 1
        RESULTS.append(("FAIL", name, detail))

def run(cmd, **kw):
    return subprocess.run(cmd, shell=True, capture_output=True, text=True, **kw)

os.chdir("/home/tester/nwave-dev")
sys.path.insert(0, ".")

# ============================================================
# TEST 1: Platform contracts module exists and has all constants
# ============================================================
print("\n=== TEST 1: Platform contracts SSOT module ===\n")

from scripts.shared.platform_contracts import (
    OPENCODE_PATH_REWRITES,
    OPENCODE_PATH_REWRITE_EXCEPTIONS,
    OPENCODE_SKILL_FORBIDDEN_FIELDS,
    OPENCODE_COMMAND_FORBIDDEN_FIELDS,
)

test("OPENCODE_PATH_REWRITES has entries",
     len(OPENCODE_PATH_REWRITES) >= 4,
     f"got {len(OPENCODE_PATH_REWRITES)} rules")

test("skills path rewrite exists",
     any(s == "~/.claude/skills/" for s, _ in OPENCODE_PATH_REWRITES))

test("agents path rewrite exists",
     any(s == "~/.claude/agents/" for s, _ in OPENCODE_PATH_REWRITES))

test("nWave framework rewrite exists",
     any("nWave" in s for s, _ in OPENCODE_PATH_REWRITES))

test("DES lib exception exists",
     "~/.claude/lib/python" in OPENCODE_PATH_REWRITE_EXCEPTIONS)

test("skill forbidden fields defined",
     "user-invocable" in OPENCODE_SKILL_FORBIDDEN_FIELDS)

test("command forbidden fields defined (D3 fix)",
     "argument-hint" in OPENCODE_COMMAND_FORBIDDEN_FIELDS,
     f"fields: {OPENCODE_COMMAND_FORBIDDEN_FIELDS}")

# ============================================================
# TEST 2: Contract validator catches violations
# ============================================================
print("\n=== TEST 2: Contract validation functions ===\n")

from scripts.validation.validate_platform_contracts import validate_des_template

bad_template = 'import { PluginContext } from "opencode";\nconst is_subagent = true;'
findings = validate_des_template(bad_template)
test("validator catches wrong import (ANOMALY-3)",
     any("import" in f.message.lower() or "opencode" in f.message.lower() for f in findings))

test("validator catches is_subagent (ANOMALY-4)",
     any("subagent" in f.message.lower() for f in findings))

good_template = '''import type { Plugin } from "@opencode-ai/plugin";
export default {
  name: "nwave-des",
  hooks: {
    "tool.execute.before": async (input: { tool: string }, output: Record<string, unknown>) => {
      // enforcement logic
    }
  }
};
'''
good_findings = validate_des_template(good_template)
test("validator passes compliant template",
     len(good_findings) == 0,
     f"findings: {[f.message for f in good_findings]}")

# ============================================================
# TEST 3: CI validation script runs successfully
# ============================================================
print("\n=== TEST 3: CI validation script ===\n")

result = run(f"{sys.executable} scripts/validation/validate_platform_contracts.py")
test("validate_platform_contracts.py exits 0",
     result.returncode == 0,
     f"rc={result.returncode} stderr={result.stderr[:200]}")

# ============================================================
# TEST 4: Commands plugin uses SSOT (D3 fix verified)
# ============================================================
print("\n=== TEST 4: Commands plugin SSOT compliance ===\n")

plugin_code = Path("scripts/install/plugins/opencode_commands_plugin.py").read_text()
test("commands plugin imports platform_contracts",
     "platform_contracts" in plugin_code)

test("commands plugin has _rewrite_paths",
     "_rewrite_paths" in plugin_code)

test("commands plugin has NO hardcoded _FIELDS_TO_REMOVE (D3 fix)",
     "_FIELDS_TO_REMOVE" not in plugin_code,
     "must import from SSOT, not hardcode")

# ============================================================
# TEST 5: Skills plugin strips forbidden fields
# ============================================================
print("\n=== TEST 5: Skills plugin field stripping ===\n")

skills_code = Path("scripts/install/plugins/opencode_skills_plugin.py").read_text()
test("skills plugin imports from platform_contracts",
     "platform_contracts" in skills_code or "OPENCODE_SKILL_FORBIDDEN_FIELDS" in skills_code)

# ============================================================
# TEST 6: DES template is compliant
# ============================================================
print("\n=== TEST 6: DES template compliance ===\n")

template_path = Path("nWave/templates/opencode-des-plugin.ts.template")
if template_path.exists():
    template_content = template_path.read_text()
    test("DES template uses @opencode-ai/plugin import",
         "@opencode-ai/plugin" in template_content)
    test("DES template has no is_subagent",
         "is_subagent" not in template_content)
    has_two_params = bool(re.search(r'async\s*\(input[^)]*,\s*output', template_content))
    test("DES template uses two-param handler",
         has_two_params)
else:
    test("DES template exists", False, f"not found at {template_path}")

# ============================================================
# TEST 7: Agent permission format (matthias fix)
# ============================================================
print("\n=== TEST 7: Agent permission format ===\n")

agents_code = Path("scripts/install/plugins/opencode_agents_plugin.py").read_text()
test("agents plugin uses 'allow' string format",
     '"allow"' in agents_code)

test("agents plugin uses 'permission' key",
     "permission" in agents_code)

# ============================================================
# RESULTS
# ============================================================
print("\n" + "=" * 60)
for status, name, detail in RESULTS:
    icon = "PASS" if status == "PASS" else "FAIL"
    line = f"  [{icon}] {name}"
    if detail:
        line += f" ({detail})"
    print(line)

print(f"\n{'=' * 60}")
print(f"  Results: {TOTAL - FAILED}/{TOTAL} passing ({FAILED} failed)")
print(f"{'=' * 60}\n")

sys.exit(1 if FAILED > 0 else 0)
PYEOF

CMD ["python3", "/home/tester/test_contract_validation.py"]
